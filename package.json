{
  "name": "cdf-know-clow",
  "private": true,
  "version": "1.5.210",
  "type": "module",
  "scripts": {
    "dev:server": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "server": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx --tsconfig server/tsconfig.json server/index.ts",
    "dev": "concurrently \"npm run dev:server\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "bump": "node bump-version.cjs",
    "bump:patch": "node bump-version.cjs patch",
    "bump:minor": "node bump-version.cjs minor",
    "bump:major": "node bump-version.cjs major",
    "build:all": "npm run build && bash build-dmg-pywebview.sh",
    "build:bump-patch": "bash build-dmg-pywebview.sh --bump-patch",
    "build:bump-minor": "bash build-dmg-pywebview.sh --bump-minor",
    "build:bump-major": "bash build-dmg-pywebview.sh --bump-major",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ server/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ server/ --ext .ts,.tsx --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@mui/icons-material": "^5.15.15",
    "@mui/material": "^5.15.15",
    "@mui/x-data-grid": "^7.29.13",
    "@sentry/node": "^10.59.0",
    "@sentry/react": "^10.59.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "express": "^5.2.0",
    "fflate": "^0.8.3",
    "i18next": "^26.3.1",
    "js-yaml": "^4.2.0",
    "jsonpath-plus": "^10.4.0",
    "katex": "^0.17.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.7",
    "recharts": "^2.12.3",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sqlite-vec": "^0.1.9",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.26.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^42.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.cdf.knowclow.desktop",
    "productName": "CDF Know Clow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "artifactName": "CDF-Know-Clow-${version}-mac.${ext}",
      "electronLanguages": [
        "zh-CN"
      ],
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "main": "electron/main.mjs",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "overrides": {
    "esbuild": "$esbuild"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --max-warnings=-1",
    "server/**/*.ts": "eslint --max-warnings=-1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
