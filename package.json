{
  "name": "cdf-know-clow",
  "private": true,
  "version": "1.7.55",
  "type": "module",
  "scripts": {
    "dev:server": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "server": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx --tsconfig server/tsconfig.json server/index.ts",
    "dev": "concurrently \"npm run dev:server\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "bump": "node scripts/bump-version.cjs",
    "bump:patch": "node scripts/bump-version.cjs patch",
    "bump:minor": "node scripts/bump-version.cjs minor",
    "bump:major": "node scripts/bump-version.cjs major",
    "build:mac": "zsh scripts/package-mac-dist.sh --skip-release",
    "build:mac:patch": "zsh scripts/package-mac-dist.sh --bump-patch",
    "build:mac:minor": "zsh scripts/package-mac-dist.sh --bump-minor",
    "build:mac:major": "zsh scripts/package-mac-dist.sh --bump-major",
    "build:mac:app": "zsh scripts/package-mac-app.sh",
    "prebuild:check": "zsh scripts/pre-build-check.sh",
    "prebuild:check:quick": "zsh scripts/pre-build-check.sh --quick",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:api": "vitest run --config=vitest.config.e2e.ts",
    "test:e2e:report": "playwright show-report e2e-report",
    "tui": "tsx --tsconfig server/tsconfig.json server/tui/cli.ts",
    "tui:embedded": "tsx --tsconfig server/tsconfig.json server/tui/cli.ts --http --url http://127.0.0.1:3001",
    "tui:save-config": "tsx --tsconfig server/tsconfig.json server/tui/cli.ts --save-config",
    "tui:validate": "tsx --tsconfig server/tsconfig.json server/tui/cli.ts --validate-config",
    "lint": "eslint src/ server/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ server/ --ext .ts,.tsx --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mui/icons-material": "^5.15.15",
    "@mui/material": "^5.15.15",
    "@mui/x-data-grid": "^7.29.13",
    "@sentry/node": "^10.61.0",
    "@sentry/react": "^10.61.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.3.0",
    "cheerio": "^1.2.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "croner": "^10.0.1",
    "dayjs": "^1.11.21",
    "express": "^5.2.0",
    "fflate": "^0.8.3",
    "i18next": "^26.3.2",
    "js-yaml": "^4.2.0",
    "json5": "2.2.3",
    "jsonpath-plus": "^10.4.0",
    "katex": "^0.17.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.8",
    "recharts": "^2.12.3",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "simple-git": "^3.36.0",
    "sqlite-vec": "^0.1.9",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.9.4",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.5.2",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "postcss": "^8.4.38",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "turndown": "^7.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "overrides": {
    "esbuild": "$esbuild"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --max-warnings=-1",
    "server/**/*.ts": "eslint --max-warnings=-1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
