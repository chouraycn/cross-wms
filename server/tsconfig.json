{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2023", "DOM"],
    "types": ["vitest/globals", "node"],
    "outDir": "../dist-server",
    "rootDir": "..",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "jsx": "preserve",
    "paths": {
      "@src/*": ["../src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "../src", "**/__tests__/**", "tui/**"]
}
