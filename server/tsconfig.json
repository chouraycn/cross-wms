{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2023", "DOM"],
    "types": ["vitest/globals", "node"],
    "outDir": "../dist-server",
    "rootDir": "..",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "jsx": "preserve",
    "paths": {
      "@src/*": ["../src/*"],
      "@openclaw/media-core/*": ["../packages/media-core/src/*"],
      "@openclaw/normalization-core/*": ["../packages/normalization-core/src/*"],
      "@cdf-know/memory-host-sdk": ["../packages/memory-host-sdk/src/index.ts"],
      "@cdf-know/memory-host-sdk/*": ["../packages/memory-host-sdk/src/*"],
      "@cdf-know/media-generation-core/*": ["../packages/media-generation-core/src/*"],
      "@cdf-know/gateway-protocol/*": ["../packages/gateway-protocol/src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "../src", "**/__tests__/**", "tui/**"]
}
