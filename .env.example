# CrossWMS 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ========== 搜索引擎 API（可选） ==========
# 配置后将在搜索时优先使用，未配置则使用必应国内版 + 360搜索

# Kimi (Moonshot AI) 搜索 API
# 申请地址: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=
MOONSHOT_API_KEY=

# MiniMax 搜索 API
# 申请地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ========== AI 模型 API（按需配置） ==========
# OpenAI
OPENAI_API_KEY=

# Moonshot (Kimi)
# MOONSHOT_API_KEY=（同上）

# MiniMax
# MINIMAX_API_KEY=（同上）

# ========== 服务器配置 ==========
PORT=3001
NODE_TLS_REJECT_UNAUTHORIZED=0
