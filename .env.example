# ============================================================
# Cross-WMS Server - Environment Configuration Example
# ============================================================
# Copy this file to .env and customize values for your environment
# All variables use CROSS_WMS_ prefix

# ============================================================
# Server Configuration
# ============================================================

# Server port (default: 3000)
CROSS_WMS_APP_PORT=3000

# Application name (default: 'Cross-WMS')
CROSS_WMS_APP_NAME=Cross-WMS

# ============================================================
# Logging Configuration
# ============================================================

# Log level: debug, info, warn, error (default: info)
CROSS_WMS_LOGGING_LEVEL=info

# Redact sensitive data in logs: true, false (default: true)
CROSS_WMS_LOGGING_REDACT_SENSITIVE=true

# ============================================================
# Model Configuration
# ============================================================

# Default model reference (e.g., 'openai:gpt-4o', 'ollama:deepseek-chat')
CROSS_WMS_MODELS_DEFAULT=openai:gpt-4o

# ============================================================
# Agent Configuration
# ============================================================

# Maximum concurrent agent instances (default: 5)
CROSS_WMS_AGENTS_MAX_CONCURRENT=5

# Default agent model
CROSS_WMS_AGENTS_MODEL=openai:gpt-4o

# ============================================================
# Session Configuration
# ============================================================

# Session main key (auto-generated if not set)
# CROSS_WMS_SESSION_MAIN_KEY=your-secret-key

# ============================================================
# Cron Configuration
# ============================================================

# Maximum concurrent cron runs (default: 3)
CROSS_WMS_CRON_MAX_CONCURRENT_RUNS=3

# ============================================================
# Talk/Speech Configuration
# ============================================================

# Talk provider: none, macos, windows, linux (default: none)
CROSS_WMS_TALK_PROVIDER=none

# Speech locale (e.g., zh-CN, en-US)
CROSS_WMS_TALK_SPEECH_LOCALE=zh-CN

# ============================================================
# Message Configuration
# ============================================================

# Ack reaction scope: none, user, everyone (default: user)
CROSS_WMS_MESSAGES_ACK_REACTION_SCOPE=user

# ============================================================
# Database Configuration
# ============================================================

# Database path (relative to server directory)
DB_PATH=./data/cdf-know.db

# ============================================================
# Development Only
# ============================================================

# Node environment: development, production (default: production)
NODE_ENV=production

# Disable ONNX native download (for CI/testing)
# ONNX_DISABLE_NATIVE_DOWNLOAD=1
